<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
        "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.example.agent-runner</string>

  <key>ProgramArguments</key>
  <array>
    <string>/path/to/.venv/bin/agent-runner</string>
    <string>--config</string>
    <string>/path/to/agent-runner.toml</string>
    <string>round</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/path/to/your/project</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/usr/bin:/bin</string>
  </dict>

  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>
  <key>ThrottleInterval</key>
  <integer>3</integer>

  <key>StandardOutPath</key>
  <string>/path/to/logs/launchd-stdout.log</string>
  <key>StandardErrorPath</key>
  <string>/path/to/logs/launchd-stderr.log</string>
</dict>
</plist>
